FROM golang:1.23-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/ingestion ./cmd/ingestion/...

FROM alpine:3.20

RUN apk --no-cache add ca-certificates

WORKDIR /app

COPY --from=builder /bin/ingestion /app/ingestion

EXPOSE 8080

ENTRYPOINT ["/app/ingestion"]
